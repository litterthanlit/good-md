{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Houston-MD",
  "version": "0.1.0",
  "identifier": "com.houston.reader",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Houston-MD",
        "width": 1100,
        "height": 750,
        "minWidth": 600,
        "minHeight": 400
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown document",
        "description": "Markdown document",
        "role": "Viewer",
        "mimeType": "text/markdown",
        "rank": "Default"
      },
      {
        "ext": ["pdf"],
        "name": "PDF document",
        "description": "PDF document",
        "role": "Viewer",
        "mimeType": "application/pdf",
        "rank": "Default"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
